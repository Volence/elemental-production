# Elemental Production — Environment Configuration
# Copy this file to .env and fill in your values.
# When running as Electron app, this file lives in your user data directory.

# FACEIT API Key (for match integration)
FACEIT_API_KEY=

# OBS WebSocket connection
OBS_WS_HOST=localhost
OBS_WS_PORT=4455
OBS_WS_PASSWORD=

# Server port
PORT=3001
